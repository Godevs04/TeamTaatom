# Backend API (required in production)
BACKEND_ORIGIN=https://api.example.com

# Development: Next.js proxies /api/v1 to localhost:3000 by default. Set BACKEND_PROXY_TARGET
# only if you need to proxy to another host (e.g. BACKEND_PROXY_TARGET=http://192.168.1.33:3000).
# BACKEND_PROXY_TARGET=

# Public URL of this web app (optional; for SEO and links)
NEXT_PUBLIC_WEB_URL=https://web.example.com

# Optional: analytics
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
# NEXT_PUBLIC_GTM_ID=

# Optional: image CDN
# IMAGE_CDN_BASE_URL=
# NEXT_PUBLIC_CDN_IMAGE_BASE=

# Optional: Google Maps (TripScore map + dynamic place/geocode)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Copy to .env.local and fill in values. Do not commit .env.local.
