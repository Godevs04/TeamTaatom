# =============================================================================
# Taatom Backend — environment template
# Copy to `.env` (or `.env.local`) and fill values. Never commit real secrets.
# Keys below are from process.env usage in src/, scripts/, and related config.
#
# Production stack (EC2): MongoDB Atlas, Upstash Redis, Sevalla storage,
# Firebase, Google Maps, Cashfree, Sentry — all external; no local DB containers.
# Docker Compose sets PORT=3000; keep NODE_ENV=production on the server.
# =============================================================================

# -----------------------------------------------------------------------------
# Required at boot (validateEnvironment in src/server.js)
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=5000
# Production (Atlas): mongodb+srv://USER:PASS@CLUSTER/DB?retryWrites=true&w=majority
MONGO_URL=mongodb://localhost:27017/taatom
JWT_SECRET=change-me-to-a-long-random-secret

# -----------------------------------------------------------------------------
# Deployment / NODE_ENV overrides
# If any of these signal staging/production, server forces NODE_ENV=production
# -----------------------------------------------------------------------------
# STAGING=false
# PRODUCTION=false
# DEPLOY_ENV=

# -----------------------------------------------------------------------------
# MongoDB pool / DB name
# -----------------------------------------------------------------------------
# MONGO_DB_NAME=TaatomProd
# MONGO_MAX_POOL_SIZE=10
# MONGO_MIN_POOL_SIZE=2
# MONGO_MAX_IDLE_TIME_MS=30000
# MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
# MONGO_SOCKET_TIMEOUT_MS=45000
# MONGO_CONNECT_TIMEOUT_MS=10000

# Script/test aliases (not used by server.js boot — scripts/tests only)
# MONGODB_URI=
# DATABASE_URI=
# MONGODB_TEST_URI=

# -----------------------------------------------------------------------------
# Redis (optional — falls back to in-memory)
# Production: Upstash REDIS_URL (rediss://...) preferred over HOST/PORT
# -----------------------------------------------------------------------------
# REDIS_URL=rediss://default:TOKEN@HOST:6379
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# RATE_LIMIT_REDIS_URL=

# -----------------------------------------------------------------------------
# CORS / public URLs / deep links
# -----------------------------------------------------------------------------
# FRONTEND_URL=https://app.example.com
# WEB_FRONTEND_URL=https://www.example.com
# WEB_SHARE_URL=https://taatom.com
# SUPERADMIN_URL=https://admin.example.com
# API_BASE_URL=https://api.example.com
# API_BASE_URL_PROD=
# API_PUBLIC_URL=
# APP_DEEP_LINK_BASE=taatom://
# LOGO_IMAGE=
# APP_VERSION=1.0.0
# TAATOM_OFFICIAL_USER_ID=000000000000000000000001

# -----------------------------------------------------------------------------
# Socket.IO (production requires WS_ALLOWED_ORIGIN)
# -----------------------------------------------------------------------------
# WS_ALLOWED_ORIGIN=https://www.example.com
# WS_PATH=/socket.io

# -----------------------------------------------------------------------------
# Sevalla / R2 object storage (primary media)
# -----------------------------------------------------------------------------
# SEVALLA_STORAGE_ENDPOINT=
# SEVALLA_STORAGE_REGION=auto
# SEVALLA_STORAGE_ACCESS_KEY=
# SEVALLA_STORAGE_SECRET_KEY=
# SEVALLA_STORAGE_BUCKET=
# SEVALLA_STORAGE_PUBLIC_URL=

# -----------------------------------------------------------------------------
# Cloudinary (legacy / helpers)
# -----------------------------------------------------------------------------
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# -----------------------------------------------------------------------------
# AWS S3 (legacy config in src/config/s3.js)
# -----------------------------------------------------------------------------
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET_NAME=
# AWS_CLOUDFRONT_URL=

# -----------------------------------------------------------------------------
# Firebase Admin (push / FCM)
# Prefer FIREBASE_PRIVATE_KEY_BASE64 in cloud environments
# -----------------------------------------------------------------------------
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY_BASE64=
# FIREBASE_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# Google OAuth + Maps + Overpass
# -----------------------------------------------------------------------------
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=
# GOOGLE_MAPS_API_KEY=
# OVERPASS_API_URL=https://overpass-api.de/api/interpreter

# -----------------------------------------------------------------------------
# Brevo email (OTP / SuperAdmin 2FA)
# -----------------------------------------------------------------------------
# BREVO_API_KEY=
# SMTP_FROM=contact@taatom.com

# -----------------------------------------------------------------------------
# Cashfree (subscriptions / payments)
# -----------------------------------------------------------------------------
# CASHFREE_ENV=sandbox
# CASHFREE_APP_ID=
# CASHFREE_SECRET_KEY=

# -----------------------------------------------------------------------------
# Cashfree Payouts — documented for ops; not read by current server runtime
# (kept so deploy checklists stay complete; do not invent fake app wiring)
# Falls back conceptually to CASHFREE_ENV if CASHFREE_PAYOUT_ENV is unset.
# -----------------------------------------------------------------------------
# CASHFREE_PAYOUT_ENV=sandbox
# CASHFREE_PAYOUT_APP_ID=
# CASHFREE_PAYOUT_SECRET_KEY=
# CASHFREE_PAYOUT_API_VERSION=2024-01-01

# -----------------------------------------------------------------------------
# Payout fee knobs (src/jobs/payoutCalculation.js — process.env[name])
# Defaults match product fee sheet / commission 20%
# -----------------------------------------------------------------------------
# TAATOM_GATEWAY_FEE_DOMESTIC_PERCENT=2
# TAATOM_GATEWAY_FEE_INTL_PERCENT=3.5
# TAATOM_FX_CHARGE_PERCENT=1.5
# TAATOM_COMMISSION_PERCENT=20
# TAATOM_GST_ON_COMMISSION_PERCENT=18
# TAATOM_WISE_TRANSFER_FEE_PERCENT=1

# -----------------------------------------------------------------------------
# Wise API — reserved / documented; not read by server code yet
# -----------------------------------------------------------------------------
# WISE_API_TOKEN=

# -----------------------------------------------------------------------------
# OSRM — documented for map-snapping infra; not read by Express app code
# -----------------------------------------------------------------------------
# OSRM_SERVER_URL=http://localhost:5000

# -----------------------------------------------------------------------------
# Sentry
# -----------------------------------------------------------------------------
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=
# SENTRY_RELEASE=
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_SEND_DEFAULT_PII=true
# SENTRY_DEBUG=false

# -----------------------------------------------------------------------------
# Feature flags / logging / body limits
# -----------------------------------------------------------------------------
# ENABLE_BACKGROUND_JOBS=true
# ENABLE_CACHING=true
# ENABLE_QUERY_MONITORING=true
# ENABLE_REQUEST_LOGGING=true
# ENABLE_SWAGGER=false
# LOG_LEVEL=info
# STRUCTURED_LOGGING=false
# LOG_REQUEST_BODY=false
# LOG_RESPONSE_BODY=false
# SLOW_QUERY_THRESHOLD=100
# MAX_JSON_BODY_SIZE=1mb
# MAX_URLENCODED_BODY_SIZE=1mb

# -----------------------------------------------------------------------------
# Swagger OAuth (optional; when ENABLE_SWAGGER=true)
# -----------------------------------------------------------------------------
# SWAGGER_OAUTH_CLIENT_ID=
# SWAGGER_OAUTH_CLIENT_SECRET=
# SWAGGER_OAUTH_REALM=

# -----------------------------------------------------------------------------
# PM2 (ecosystem.config.js only — not required for Docker npm start)
# -----------------------------------------------------------------------------
# PM2_INSTANCES=1
# PM2_EXEC_MODE=fork

# -----------------------------------------------------------------------------
# Scripts / CI / tests only
# -----------------------------------------------------------------------------
# DRY_RUN=true
# CI=
# JEST_WORKER_ID=
