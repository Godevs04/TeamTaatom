# Copy to `.env.local` (or `.env`) and fill values. Never commit real secrets.

# Mongo & auth (required — see server validateEnvironment)
# MONGO_URL=
# JWT_SECRET=
# NODE_ENV=development

# Web app origin (CORS + Cashfree subscription return URL for `X-Platform: web`)
# WEB_FRONTEND_URL=http://localhost:3001

# Mobile deep link base for Cashfree return (no trailing path)
# APP_DEEP_LINK_BASE=taatom://

# Cashfree subscriptions (required for Connect subscribe / cancel)
# CASHFREE_ENV=sandbox
# CASHFREE_APP_ID=
# CASHFREE_SECRET_KEY=

# Payout fee knobs (optional — defaults match product fee sheet, commission 20%)
# TAATOM_GATEWAY_FEE_DOMESTIC_PERCENT=2
# TAATOM_GATEWAY_FEE_INTL_PERCENT=3.5
# TAATOM_FX_CHARGE_PERCENT=1.5
# TAATOM_COMMISSION_PERCENT=20
# TAATOM_GST_ON_COMMISSION_PERCENT=18
# TAATOM_WISE_TRANSFER_FEE_PERCENT=1

# Wise API (reserved for future payout automation — not read by server code yet)
# WISE_API_TOKEN=
